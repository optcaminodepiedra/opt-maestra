generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MASTER_ADMIN
  OWNER
  SUPERIOR
  MANAGER
  MANAGER_OPS
  ACCOUNTING
  SALES
  RESERVATIONS
  INVENTORY
  STAFF_MAINTENANCE
  MANAGER_RESTAURANT
  STAFF_CASHIER
  STAFF_WAITER
  STAFF_BAR
  STAFF_KITCHEN
  MANAGER_HOTEL
  STAFF_RECEPTION
  STAFF_HOUSEKEEPING
  MANAGER_RANCH
  STAFF_EXPERIENCES
  STAFF_FIELD
  STAFF_STORE
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum WithdrawalStatus {
  REQUESTED
  APPROVED
  REJECTED
}

enum WithdrawalKind {
  PETTY_CASH
  LARGE_REQUEST
}

model Business {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  cashpoints  Cashpoint[]
  sales       Sale[]
  expenses    Expense[]
  shifts      Shift[]
  withdrawals Withdrawal[]

  users        User[] @relation("UserBusiness")
  primaryUsers User[] @relation("PrimaryBusiness")
  
  vacationRequests VacationRequest[]

  tasks Task[]

  restaurantTables RestaurantTable[] @relation("BusinessRestaurantTables")
  menuItems        MenuItem[]        @relation("BusinessMenuItems")
  restaurantOrders RestaurantOrder[] @relation("BusinessRestaurantOrders")

  inventoryItems InventoryItem[]
  inventoryMoves InventoryMovement[]
  requisitions   Requisition[]

  hotelRoomTypes    HotelRoomType[]
  hotelRooms        HotelRoom[]
  hotelReservations HotelReservation[]
  hotelCharges      HotelCharge[]
  hotelFolios       HotelFolio[]
  hotelPayments     HotelPayment[]

  scheduledShifts ScheduledShift[] @relation("BusinessScheduledShifts")

  userAccess UserBusinessAccess[]
    // ✅ Hotel al que este negocio sirve alimentos (Bodega 4 → Camino de Piedra)
  // Si el restaurante está dentro de su propio hotel, apunta a sí mismo.
  linkedHotelBusinessId String?
  linkedHotel           Business?  @relation("BusinessLinkedHotel", fields: [linkedHotelBusinessId], references: [id])
  linkedByRestaurants   Business[] @relation("BusinessLinkedHotel")

  importBatches ImportBatch[]

  @@index([linkedHotelBusinessId])
}

model Cashpoint {
  id         String   @id @default(cuid())
  name       String
  businessId String
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
  shifts   Shift[]
  sales    Sale[]

  menuItems MenuItem[]

  restaurantTables RestaurantTable[] @relation("CashpointRestaurantTables")

  withdrawals Withdrawal[]

  @@unique([businessId, name])
}

model User {
  id           String   @id @default(cuid())
  fullName     String   @unique
  username     String   @unique
  email        String?  @unique
  passwordHash String
  role         Role
  requiresClockIn Boolean @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  // ✅ RRHH
  jobTitle   String?
  department String?
  hireDate   DateTime? @db.Date

  pinHash      String?
  pinUpdatedAt DateTime?

  businessId String?
  business   Business? @relation("UserBusiness", fields: [businessId], references: [id])

  primaryBusinessId String?
  primaryBusiness   Business? @relation("PrimaryBusiness", fields: [primaryBusinessId], references: [id])

  sales                Sale[]
  expenses             Expense[]
  shifts               Shift[]
  withdrawalsRequested Withdrawal[] @relation("RequestedBy")
  withdrawalsApproved  Withdrawal[] @relation("ApprovedBy")

  assignedTasks Task[] @relation("AssignedTasks")
  createdTasks  Task[] @relation("CreatedTasks")

  taskComments    TaskComment[]
  taskAttachments TaskAttachment[]

  restaurantOrders RestaurantOrder[] @relation("UserRestaurantOrders")

  inventoryMovesCreated InventoryMovement[] @relation("InventoryMoveCreatedBy")
  reqCreated            Requisition[]       @relation("ReqCreatedBy")
  reqApproved           Requisition[]       @relation("ReqApprovedBy")

  hotelReservations HotelReservation[] @relation("UserHotelReservations")
  hotelFolios       HotelFolio[]
  hotelPayments     HotelPayment[]

  workDays WorkDay[]
vacationRequests        VacationRequest[] @relation("UserVacationRequests")
vacationRequestsDecided VacationRequest[] @relation("VacationRequestDecidedBy")
vacationBalances        VacationBalance[]

  scheduledShifts        ScheduledShift[] @relation("UserScheduledShifts")
  scheduledShiftsCreated ScheduledShift[] @relation("ScheduledShiftCreatedBy")

  businessAccess UserBusinessAccess[]

  importBatchId        String?
importBatch          ImportBatch?  @relation("UserImportBatch", fields: [importBatchId], references: [id])
importBatchesCreated ImportBatch[] @relation("ImportBatchCreatedBy")
importBatchesReverted ImportBatch[] @relation("ImportBatchRevertedBy")

}

model UserBusinessAccess {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([userId])
  @@index([businessId])
}

model Shift {
  id          String    @id @default(cuid())
  businessId  String
  cashpointId String
  openedById  String
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  notes       String?

  expectedCashCents     Int @default(0)
  expectedCardCents     Int @default(0)
  expectedTransferCents Int @default(0)

  countedCashCents     Int?
  countedCardCents     Int?
  countedTransferCents Int?

  business  Business  @relation(fields: [businessId], references: [id])
  cashpoint Cashpoint @relation(fields: [cashpointId], references: [id])
  openedBy  User      @relation(fields: [openedById], references: [id])

  sales Sale[]

  @@index([businessId, openedAt])
}

model Sale {
  id          String        @id @default(cuid())
  businessId  String
  cashpointId String
  shiftId     String?
  userId      String
  amountCents Int
  method      PaymentMethod
  concept     String
  createdAt   DateTime      @default(now())

  business  Business  @relation(fields: [businessId], references: [id])
  cashpoint Cashpoint @relation(fields: [cashpointId], references: [id])
  shift     Shift?    @relation(fields: [shiftId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

importBatchId String?
importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])

  @@index([businessId, createdAt])
}

model Expense {
  id          String   @id @default(cuid())
  businessId  String
  userId      String
  amountCents Int
  category    String
  note        String?
  evidenceUrl String?
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
importBatchId String?
importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])

  @@index([businessId, createdAt])
}

model Withdrawal {
  id          String           @id @default(cuid())
  businessId  String
  amountCents Int
  reason      String?
  status      WithdrawalStatus @default(REQUESTED)

  cashpointId String?
  cashpoint   Cashpoint? @relation(fields: [cashpointId], references: [id])

  kind WithdrawalKind @default(PETTY_CASH)

  requestedById String
  approvedById  String?

  createdAt DateTime  @default(now())
  decidedAt DateTime?

  business    Business @relation(fields: [businessId], references: [id])
  requestedBy User     @relation("RequestedBy", fields: [requestedById], references: [id])
  approvedBy  User?    @relation("ApprovedBy", fields: [approvedById], references: [id])

importBatchId String?
importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])

  @@index([businessId, createdAt])
  @@index([cashpointId, createdAt])
  @@index([kind, status])
}

enum TaskType {
  ACTIVITY
  TICKET
}

enum TaskStatus {
  TODO
  DOING
  BLOCKED
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Area {
  OPERATIONS
  SYSTEMS
  MARKETING
  ADMIN
}

model Task {
  id          String  @id @default(cuid())
  title       String
  description String?

  type     TaskType
  status   TaskStatus
  priority Priority
  area     Area

  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])

  assignedId String?
  assigned   User?   @relation("AssignedTasks", fields: [assignedId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedTasks", fields: [createdById], references: [id])

  startDate  DateTime?
  dueDate    DateTime?
  endDate    DateTime?
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments    TaskComment[]
  attachments TaskAttachment[]

  @@index([type, status])
  @@index([businessId])
  @@index([assignedId])
  @@index([createdById])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  body      String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId, createdAt])
}

model TaskAttachment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  name      String
  url       String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId, createdAt])
}

enum OrderStatus {
  OPEN
  SENT
  SERVED
  PAID
  CANCELED
}

enum KitchenStatus {
  NEW
  PREPARING
  READY
  DELIVERED
  CANCELED
}

model RestaurantTable {
  id         String  @id @default(cuid())
  businessId String
  name       String
  capacity   Int     @default(4)
  isActive   Boolean @default(true)

  cashpointId String?
  cashpoint   Cashpoint? @relation("CashpointRestaurantTables", fields: [cashpointId], references: [id])

  area      String?
  posX      Int?
  posY      Int?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business          @relation("BusinessRestaurantTables", fields: [businessId], references: [id])
  orders   RestaurantOrder[]

  @@unique([businessId, name])
  @@index([businessId, isActive])
  @@index([businessId, area])
  @@index([cashpointId])
}

model MenuItem {
  id         String @id @default(cuid())
  businessId String

  cashpointId String?
  cashpoint   Cashpoint? @relation(fields: [cashpointId], references: [id])

  name       String
  category   String
  priceCents Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business   Business              @relation("BusinessMenuItems", fields: [businessId], references: [id])
  orderItems RestaurantOrderItem[]

  @@index([businessId, isActive])
  @@index([businessId, category])
  @@index([cashpointId])
}

model RestaurantOrder {
  id         String      @id @default(cuid())
  businessId String
  tableId    String
  userId     String
  status     OrderStatus @default(OPEN)
  note       String?

  openedAt  DateTime  @default(now())
  closedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  business Business        @relation("BusinessRestaurantOrders", fields: [businessId], references: [id])
  table    RestaurantTable @relation(fields: [tableId], references: [id])
  user     User            @relation("UserRestaurantOrders", fields: [userId], references: [id])

  items RestaurantOrderItem[]

  @@index([businessId, status, openedAt])
  @@index([tableId, status])
}

model RestaurantOrderItem {
  id            String        @id @default(cuid())
  orderId       String
  menuItemId    String
  qty           Int           @default(1)
  priceCents    Int
  note          String?
  kitchenStatus KitchenStatus @default(NEW)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order    RestaurantOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem        @relation(fields: [menuItemId], references: [id])

  @@index([orderId, createdAt])
  @@index([kitchenStatus, createdAt])
}

enum StockUnit {
  PIECE
  KG
  LT
  BOX
  PACK
}

enum MovementType {
  IN
  OUT
  ADJUST
  TRANSFER
}

enum RequisitionStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ORDERED
  RECEIVED
  CLOSED
}

model InventoryItem {
  id         String    @id @default(cuid())
  businessId String
  sku        String?
  name       String
  category   String?
  unit       StockUnit @default(PIECE)

  minQty    Int @default(0)
  onHandQty Int @default(0)

  lastPriceCents Int     @default(0)
  supplierName   String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business  Business            @relation(fields: [businessId], references: [id])
  movements InventoryMovement[]
  reqItems  RequisitionItem[]

  importBatchId String?
importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])

  @@index([businessId, isActive])
  @@index([businessId, name])
}

model InventoryMovement {
  id          String       @id @default(cuid())
  businessId  String
  itemId      String
  type        MovementType
  qty         Int
  note        String?
  createdById String
  createdAt   DateTime     @default(now())

  business  Business      @relation(fields: [businessId], references: [id])
  item      InventoryItem @relation(fields: [itemId], references: [id])
  createdBy User          @relation("InventoryMoveCreatedBy", fields: [createdById], references: [id])

  @@index([businessId, createdAt])
  @@index([itemId, createdAt])
}

model Requisition {
  id         String            @id @default(cuid())
  businessId String
  status     RequisitionStatus @default(DRAFT)
  title      String
  note       String?
  neededBy   DateTime?

  createdById  String
  approvedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business   Business @relation(fields: [businessId], references: [id])
  createdBy  User     @relation("ReqCreatedBy", fields: [createdById], references: [id])
  approvedBy User?    @relation("ReqApprovedBy", fields: [approvedById], references: [id])

  items RequisitionItem[]

  @@index([businessId, status, createdAt])
}

model RequisitionItem {
  id            String @id @default(cuid())
  requisitionId String
  itemId        String

  qtyRequested Int
  qtyApproved  Int?
  qtyReceived  Int?

  estimatedPriceCents Int @default(0)

  note      String?
  createdAt DateTime @default(now())

  requisition Requisition   @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  item        InventoryItem @relation(fields: [itemId], references: [id])

  @@index([requisitionId])
  @@index([itemId])
}

enum CatalogType {
  EXPENSE_CATEGORY
  SALE_CONCEPT
  TASK_AREA_TAG
  INVENTORY_CATEGORY
  GENERIC
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model CatalogItem {
  id        String      @id @default(cuid())
  type      CatalogType
  name      String
  isActive  Boolean     @default(true)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([type, name])
  @@index([type, isActive])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actorName String?
  action    String
  target    String
  targetId  String?
  before    String?
  after     String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  DIRTY
  OUT_OF_SERVICE
  MAINTENANCE
  BLOCKED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELED
  NO_SHOW
}

enum RoomTypeKind {
  STANDARD
  SUITE
  GLAMPING
  CONTAINER
}

model HotelRoomType {
  id         String @id @default(cuid())
  businessId String

  name           String
  description    String?
  basePriceCents Int
  capacity       Int
  kind           RoomTypeKind @default(STANDARD)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business    @relation(fields: [businessId], references: [id])
  rooms    HotelRoom[]

  @@unique([businessId, name])
  @@index([businessId])
}

model HotelRoom {
  id         String @id @default(cuid())
  businessId String
  roomTypeId String

  name     String
  floor    String?
  status   RoomStatus @default(AVAILABLE)
  isActive Boolean    @default(true)

  area      String?
  posX      Int?
  posY      Int?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business     Business           @relation(fields: [businessId], references: [id])
  roomType     HotelRoomType      @relation(fields: [roomTypeId], references: [id])
  reservations HotelReservation[]

  @@unique([businessId, name])
  @@index([businessId, status])
  @@index([businessId, isActive])
  @@index([roomTypeId])
}

model HotelGuest {
  id         String  @id @default(cuid())
  fullName   String
  phone      String?
  email      String?
  documentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations HotelReservation[]

  @@index([fullName])
  @@index([phone])
  @@index([email])
}

model HotelReservation {
  id         String @id @default(cuid())
  businessId String
  roomId     String
  guestId    String
  userId     String

  checkIn  DateTime
  checkOut DateTime

  status ReservationStatus @default(CONFIRMED)

  adults   Int @default(1)
  children Int @default(0)

  totalCents   Int @default(0)
  depositCents Int @default(0)

  notes String?

    // ✅ Servicio de alimentos (planeación de cocina por Judith)
  hasFoodService   Boolean @default(false)
  foodServicePax   Int?
  foodServiceNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business   @relation(fields: [businessId], references: [id])
  room     HotelRoom  @relation(fields: [roomId], references: [id])
  guest    HotelGuest @relation(fields: [guestId], references: [id])
  user     User       @relation("UserHotelReservations", fields: [userId], references: [id])

  charges HotelCharge[]
  folio   HotelFolio?

  importBatchId String?
importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])

  @@index([businessId, status])
  @@index([roomId, status])
  @@index([guestId])
  @@index([userId])
  @@index([roomId, checkIn, checkOut])
}

model HotelCharge {
  id            String @id @default(cuid())
  businessId    String
  reservationId String

  amountCents Int
  concept     String
  note        String?

  createdAt DateTime @default(now())

  business    Business         @relation(fields: [businessId], references: [id])
  reservation HotelReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId, createdAt])
  @@index([businessId, createdAt])
}

enum FolioStatus {
  OPEN
  CLOSED
  CANCELED
}

model HotelFolio {
  id            String @id @default(cuid())
  businessId    String
  reservationId String @unique

  totalChargesCents  Int @default(0)
  totalPaymentsCents Int @default(0)
  depositCents       Int @default(0)

  isClosed   Boolean   @default(false)
  closedAt   DateTime?
  closedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business    Business         @relation(fields: [businessId], references: [id])
  reservation HotelReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  closedBy User? @relation(fields: [closedById], references: [id])

  payments HotelPayment[]

  @@index([businessId, createdAt])
}

model HotelPayment {
  id         String @id @default(cuid())
  businessId String
  folioId    String

  amountCents Int
  method      PaymentMethod
  note        String?

  createdById String?
  createdAt   DateTime @default(now())

  business  Business   @relation(fields: [businessId], references: [id])
  folio     HotelFolio @relation(fields: [folioId], references: [id], onDelete: Cascade)
  createdBy User?      @relation(fields: [createdById], references: [id])

  @@index([folioId, createdAt])
  @@index([businessId, createdAt])
}

model WorkDay {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  date         DateTime      @db.Date
  status       WorkDayStatus @default(OPEN)
  totalMinutes Int           @default(0)

  punches TimePunch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TimePunch {
  id        String  @id @default(cuid())
  workDayId String
  workDay   WorkDay @relation(fields: [workDayId], references: [id], onDelete: Cascade)

  type      PunchType
  timestamp DateTime  @default(now())

  photoUrl   String?
  gpsLat     Float?
  gpsLng     Float?
  deviceType String

  note       String?
  isAdjusted Boolean @default(false)
}

enum WorkDayStatus {
  OPEN
  NEEDS_REVIEW
  APPROVED
}

enum PunchType {
  ENTRADA
  INICIO_COMIDA
  FIN_COMIDA
  INICIO_COMPRAS
  FIN_COMPRAS
  SALIDA
}

model AccountingPeriod {
  id          String    @id @default(cuid())
  month       Int
  year        Int

  isClosed    Boolean   @default(false)
  closedAt    DateTime?
  closedByRef String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month])
}

enum ScheduledShiftStatus {
  PLANNED
  CONFIRMED
  ABSENT
  CANCELED
}

model ScheduledShift {
  id         String   @id @default(cuid())
  userId     String
  businessId String

  date      DateTime @db.Date
  startTime String?
  endTime   String?
  role      String?
  note      String?

  status ScheduledShiftStatus @default(PLANNED)

  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation("UserScheduledShifts", fields: [userId], references: [id])
  business  Business @relation("BusinessScheduledShifts", fields: [businessId], references: [id])
  createdBy User     @relation("ScheduledShiftCreatedBy", fields: [createdById], references: [id])

  @@unique([userId, businessId, date])
  @@index([businessId, date])
  @@index([userId, date])
  @@index([date])
}

enum VacationType {
  VACATION
  UNPAID_LEAVE
  SICK_LEAVE
  PERSONAL
}

enum VacationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

model VacationRequest {
  id         String @id @default(cuid())
  userId     String
  businessId String?

  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  totalDays Int

  type   VacationType   @default(VACATION)
  status VacationStatus @default(PENDING)
  note   String?

  decidedById  String?
  decidedAt    DateTime?
  decisionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User      @relation("UserVacationRequests", fields: [userId], references: [id], onDelete: Cascade)
  business  Business? @relation(fields: [businessId], references: [id])
  decidedBy User?     @relation("VacationRequestDecidedBy", fields: [decidedById], references: [id])

  @@index([userId])
  @@index([status])
  @@index([startDate])
}

model VacationBalance {
  id          String @id @default(cuid())
  userId      String
  year        Int
  earnedDays  Int @default(12)
  usedDays    Int @default(0)
  pendingDays Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
  @@index([userId])
}

enum ImportEntityType {
  SALES
  EXPENSES
  WITHDRAWALS
  HOTEL_RESERVATIONS
  GUESTS
  INVENTORY_ITEMS
  EMPLOYEES
}

enum ImportBatchStatus {
  PROCESSING
  COMPLETED
  FAILED
  REVERTED
}

model ImportBatch {
  id          String             @id @default(cuid())
  entityType  ImportEntityType
  businessId  String?
  filename    String
  totalRows   Int                @default(0)
  successRows Int                @default(0)
  errorRows   Int                @default(0)
  errors      Json?
  status      ImportBatchStatus  @default(PROCESSING)
  note        String?

  createdById  String
  createdAt    DateTime   @default(now())
  completedAt  DateTime?
  revertedAt   DateTime?
  revertedById String?

  createdBy  User      @relation("ImportBatchCreatedBy", fields: [createdById], references: [id])
  revertedBy User?     @relation("ImportBatchRevertedBy", fields: [revertedById], references: [id])
  business   Business? @relation(fields: [businessId], references: [id])

  sales             Sale[]
  expenses          Expense[]
  withdrawals       Withdrawal[]
  hotelReservations HotelReservation[]
  inventoryItems    InventoryItem[]
  users             User[]             @relation("UserImportBatch")
  // guests         Guest[]  // descomenta si tu schema tiene Guest

  @@index([entityType])
  @@index([businessId])
  @@index([createdAt])
  @@index([status])
}